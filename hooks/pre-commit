#!/bin/bash
# Pre-commit hook to check formatting and clippy

set -e

echo "Running cargo fmt check..."
if ! cargo fmt --all -- --check; then
    echo "❌ Code is not formatted. Run 'cargo fmt --all' to fix."
    exit 1
fi

echo "Running cargo clippy..."
if ! cargo clippy --workspace --all-targets --message-format=short -- -D warnings; then
    echo "❌ Clippy found warnings. Fix them before committing."
    exit 1
fi

echo "Checking documentation coverage..."
if ! doc_output=$(RUSTDOCFLAGS="-D missing_docs -D rustdoc::broken_intra_doc_links" cargo doc --workspace --no-deps 2>&1); then
    echo "$doc_output" | grep '^error' | head -20
    echo "❌ Documentation errors. Run: RUSTDOCFLAGS='-D missing_docs -D rustdoc::broken_intra_doc_links' cargo doc --workspace --no-deps"
    exit 1
fi

echo "Running tests..."
if ! test_output=$(cargo test --workspace 2>&1); then
    echo "$test_output" | tail
    echo "❌ Tests failed. Fix them before committing."
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
echo "Checking EslEventType against C ESL..."
if ! "$SCRIPT_DIR/check-event-types.sh"; then
    echo "❌ EslEventType enum is out of sync with C ESL. Update freeswitch-types/src/event.rs."
    exit 1
fi

echo "Checking HangupCause against switch_call_cause_t..."
if ! "$SCRIPT_DIR/check-hangup-causes.sh"; then
    echo "❌ HangupCause enum is out of sync with FreeSWITCH. Update freeswitch-types/src/channel.rs."
    exit 1
fi

echo "Checking ChannelState against switch_channel_state_t..."
if ! "$SCRIPT_DIR/check-channel-states.sh"; then
    echo "❌ ChannelState enum is out of sync with FreeSWITCH. Update freeswitch-types/src/channel.rs."
    exit 1
fi

echo "Checking CallState against switch_channel_callstate_t..."
if ! "$SCRIPT_DIR/check-call-states.sh"; then
    echo "❌ CallState enum is out of sync with FreeSWITCH. Update freeswitch-types/src/channel.rs."
    exit 1
fi

echo "Checking SIP header coverage against sofia.c..."
if ! "$SCRIPT_DIR/check-sip-header-prefixes.sh"; then
    echo "❌ SipHeader enum (sip-header crate) is missing headers used by FreeSWITCH sofia.c."
    exit 1
fi

echo "Checking CoreMediaVariable against set_stats()..."
if ! "$SCRIPT_DIR/check-core-media-vars.sh"; then
    echo "❌ CoreMediaVariable enum is out of sync with FreeSWITCH. Update freeswitch-types/src/variables/core_media.rs."
    exit 1
fi

echo "✅ Pre-commit checks passed"
