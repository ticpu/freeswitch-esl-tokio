#!/bin/bash
# Pre-commit hook to check formatting and clippy

set -e

echo "Running cargo fmt check..."
if ! cargo fmt --all -- --check; then
    echo "❌ Code is not formatted. Run 'cargo fmt --all' to fix."
    exit 1
fi

echo "Running cargo clippy..."
if ! cargo clippy --workspace --all-targets --message-format=short -- -D warnings; then
    echo "❌ Clippy found warnings. Fix them before committing."
    exit 1
fi

echo "Checking documentation coverage..."
if ! doc_output=$(RUSTDOCFLAGS="-D missing_docs -D rustdoc::broken_intra_doc_links" cargo doc --workspace --no-deps 2>&1); then
    echo "$doc_output" | grep '^error' | head -20
    echo "❌ Documentation errors. Run: RUSTDOCFLAGS='-D missing_docs -D rustdoc::broken_intra_doc_links' cargo doc --workspace --no-deps"
    exit 1
fi

echo "Running tests..."
if ! test_output=$(cargo test --workspace 2>&1); then
    echo "$test_output" | tail
    echo "❌ Tests failed. Fix them before committing."
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
echo "Checking enum sync against FreeSWITCH C source..."
if ! python3 "$SCRIPT_DIR/check-enums.py" --quiet; then
    echo "❌ Enum coverage out of sync with FreeSWITCH. Run: python3 hooks/check-enums.py"
    exit 1
fi

echo "✅ Pre-commit checks passed"
